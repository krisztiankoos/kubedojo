#!/usr/bin/env bash
# Agent Bridge CLI wrapper for KubeDojo
export AB_REPO_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
export AB_DB_PATH="${AB_REPO_ROOT}/.bridge/messages.db"
export AB_CONTEXT_DIR="${AB_REPO_ROOT}/docs/agent-channels"
export AB_WAKE_DIR="${AB_REPO_ROOT}/.agent/wake"
export AB_PIPELINE_ENV_KEY="KUBEDOJO_PIPELINE"
export PYTHONPATH="${AB_REPO_ROOT}/scripts:${PYTHONPATH}"

# Codex always runs in danger mode — read-only and workspace-write both starve
# it of network/filesystem. No override possible at this layer; if a caller
# really needs different behavior they must change the adapter contract.
if [ -n "${CODEX_BRIDGE_MODE:-}" ] && [ "${CODEX_BRIDGE_MODE}" != "danger" ]; then
  printf 'WARNING: CODEX_BRIDGE_MODE=%s overridden to danger — Codex requires network+FS\n' \
    "${CODEX_BRIDGE_MODE}" >&2
fi
CODEX_BRIDGE_MODE=danger
export CODEX_BRIDGE_MODE

exec python3 -m ai_agent_bridge "$@"
