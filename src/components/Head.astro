---
/**
 * Custom Head override — injects content enhancer + progress tracker scripts
 * Issue: #138, #139
 */
import type { Props } from '@astrojs/starlight/props';
import Default from '@astrojs/starlight/components/Head.astro';
---

<Default {...Astro.props}><slot /></Default>

<!-- Content Enhancer: styles War Story, Did You Know, Quiz sections -->
<script src="../scripts/content-enhancer.ts"></script>

<!-- Progress Tracker: localStorage-based module completion -->
<script src="../scripts/progress-tracker.ts"></script>

<!-- Mermaid Renderer: lazy-loads only on pages that contain Mermaid code blocks -->
<script is:inline>
	(() => {
		document.documentElement.classList.add('js-mermaid');

		if (window.__kdMermaid?.refresh) {
			window.__kdMermaid.refresh();
			return;
		}

		const MERMAID_SRC = 'https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.min.js';
		const MERMAID_PRE_SELECTOR = 'pre[data-language="mermaid"]';
		const state = {
			loadPromise: null,
			renderCount: 0,
			lastTheme: null,
		};

		function currentTheme() {
			return document.documentElement.dataset.theme === 'light' ? 'light' : 'dark';
		}

		function getMermaidBlocks(root = document) {
			return Array.from(root.querySelectorAll(MERMAID_PRE_SELECTOR));
		}

		function getHost(pre) {
			return pre.closest('figure') || pre.closest('.expressive-code') || pre;
		}

		function getDiagramSource(pre) {
			return (pre.textContent || '').replace(/\u00a0/g, ' ').trim();
		}

		function prepareHost(pre) {
			const host = getHost(pre);
			const source = getDiagramSource(pre);

			if (!source) return null;

			host.classList.add('kd-mermaid-host');
			host.dataset.mermaidState = 'loading';
			host.dataset.mermaidSource = source;

			let mount = host.querySelector('.kd-mermaid__mount');
			if (!mount) {
				mount = document.createElement('div');
				mount.className = 'kd-mermaid__mount';
				mount.setAttribute('aria-live', 'polite');
				pre.insertAdjacentElement('afterend', mount);
			}

			return host;
		}

		function loadMermaid() {
			if (window.mermaid) return Promise.resolve(window.mermaid);
			if (state.loadPromise) return state.loadPromise;

			state.loadPromise = new Promise((resolve, reject) => {
				const existing = document.querySelector('script[data-kd-mermaid-cdn]');
				if (existing) {
					existing.addEventListener('load', () => resolve(window.mermaid), { once: true });
					existing.addEventListener('error', reject, { once: true });
					return;
				}

				const script = document.createElement('script');
				script.src = MERMAID_SRC;
				script.async = true;
				script.dataset.kdMermaidCdn = 'true';
				script.addEventListener('load', () => resolve(window.mermaid), { once: true });
				script.addEventListener(
					'error',
					() => reject(new Error('Failed to load Mermaid from CDN.')),
					{ once: true }
				);
				document.head.append(script);
			});

			return state.loadPromise;
		}

		async function renderHost(host, mermaid) {
			const mount = host.querySelector('.kd-mermaid__mount');
			const source = host.dataset.mermaidSource;

			if (!mount || !source) return;

			host.dataset.mermaidState = 'loading';
			mount.replaceChildren();

			mermaid.initialize({
				startOnLoad: false,
				securityLevel: 'loose',
				theme: currentTheme() === 'light' ? 'default' : 'dark',
			});

			const renderId = `kd-mermaid-${++state.renderCount}`;

			try {
				const { svg, bindFunctions } = await mermaid.render(renderId, source);
				mount.innerHTML = svg;
				bindFunctions?.(mount);
				host.dataset.mermaidState = 'ready';
			} catch (error) {
				host.dataset.mermaidState = 'error';
				console.error('Mermaid render failed:', error);
			}
		}

		async function refresh(root = document) {
			const hosts = getMermaidBlocks(root).map(prepareHost).filter(Boolean);
			const theme = currentTheme();

			if (!hosts.length) {
				state.lastTheme = theme;
				return;
			}

			const mermaid = await loadMermaid();
			await Promise.all(hosts.map((host) => renderHost(host, mermaid)));
			state.lastTheme = theme;
		}

		function runRefresh() {
			refresh().catch((error) => {
				console.error('Mermaid initialization failed:', error);
			});
		}

		window.__kdMermaid = { refresh: runRefresh };

		if (document.readyState === 'loading') {
			document.addEventListener('DOMContentLoaded', runRefresh, { once: true });
		} else {
			runRefresh();
		}

		document.addEventListener('astro:page-load', runRefresh);

		const themeObserver = new MutationObserver(() => {
			const theme = currentTheme();
			if (theme !== state.lastTheme && document.querySelector('.kd-mermaid-host')) {
				runRefresh();
			}
		});

		themeObserver.observe(document.documentElement, {
			attributes: true,
			attributeFilter: ['data-theme'],
		});
	})();
</script>
