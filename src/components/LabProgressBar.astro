---
/**
 * LabProgressBar — Shows track-level progress on index pages.
 *
 * Usage: <LabProgressBar prefix="cka-" total={41} />
 */
interface Props {
  prefix: string;
  total: number;
}

const { prefix, total } = Astro.props;
---

<div class="lab-progress-bar" data-prefix={prefix} data-total={total}>
  <div class="lab-progress-header">
    <span class="lab-progress-label">Lab Progress</span>
    <span class="lab-progress-count" data-progress-count>0/{total} completed</span>
  </div>
  <div class="lab-progress-track">
    <div class="lab-progress-fill" data-progress-fill style="width: 0%"></div>
  </div>
</div>

<style>
  .lab-progress-bar {
    background: #F3F4F6;
    border-radius: 8px;
    padding: 0.75rem 1rem;
    margin: 1rem 0;
  }
  .lab-progress-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.375rem;
  }
  .lab-progress-label {
    font-size: 0.75rem;
    font-weight: 600;
    color: #374151;
  }
  .lab-progress-count {
    font-size: 0.75rem;
    color: #6B7280;
    font-family: 'SF Mono', 'Fira Code', monospace;
  }
  .lab-progress-track {
    height: 6px;
    background: #E5E7EB;
    border-radius: 3px;
    overflow: hidden;
  }
  .lab-progress-fill {
    height: 100%;
    border-radius: 3px;
    background: #326CE5;
    transition: width 0.5s ease;
  }
</style>

<script>
  import { getProgress } from './LabProgress';

  document.querySelectorAll('.lab-progress-bar').forEach((bar) => {
    const el = bar as HTMLElement;
    const prefix = el.dataset.prefix!;
    const total = parseInt(el.dataset.total!, 10);
    const countEl = el.querySelector('[data-progress-count]') as HTMLElement;
    const fillEl = el.querySelector('[data-progress-fill]') as HTMLElement;

    const progress = getProgress();
    let completed = 0;
    for (const [id, entry] of Object.entries(progress)) {
      if (id.startsWith(prefix) && entry.status === 'completed') {
        completed++;
      }
    }

    const pct = total > 0 ? Math.round((completed / total) * 100) : 0;
    countEl.textContent = `${completed}/${total} completed`;
    fillEl.style.width = `${pct}%`;

    // Color based on completion
    if (pct === 0) fillEl.style.background = '#9CA3AF';
    else if (pct < 50) fillEl.style.background = '#326CE5';
    else if (pct < 100) fillEl.style.background = '#F59E0B';
    else fillEl.style.background = '#00A651';
  });
</script>
